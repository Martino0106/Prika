// ── Utils ──────────────────────────────────────────────────────────────────
const fmt = n => new Intl.NumberFormat("es-CO",{style:"currency",currency:"COP",maximumFractionDigits:0}).format(n);
const today = () => new Date().toISOString().split("T")[0];

function toCSV(pedidos) {
  const rows = [["ID","Cliente","Teléfono","Productos","Total","Estado","Fecha","Hora","Nota","Despacho"]];
  pedidos.forEach(p => rows.push([
    p.id, p.cliente, p.telefono,
    p.items.map(i=>`${i.prod} x${i.cant}`).join(" | "),
    p.total, p.estado, p.fecha, p.hora, p.nota, p.despacho
  ]));
  return rows.map(r => r.map(c => `"${String(c).replace(/"/g,'""')}"`).join(",")).join("\n");
}

function downloadCSV(content, name) {
  const a = document.createElement("a");
  a.href = "data:text/csv;charset=utf-8,\uFEFF" + encodeURIComponent(content);
  a.download = name;
  a.click();
}

// ── Componentes base ───────────────────────────────────────────────────────
const Btn = ({children, onClick, variant="primary", size="md", style:s={}}) => {
  const base = {
    border:"none", borderRadius:"6px", fontWeight:500, transition:"all .15s",
    display:"inline-flex", alignItems:"center", gap:"6px",
    padding: size==="sm" ? "5px 10px" : size==="lg" ? "11px 22px" : "8px 16px",
    fontSize: size==="sm" ? "12px" : "13px",
  };
  const vars = {
    primary:  { background:G.accent, color:"#000" },
    secondary:{ background:G.card, color:G.text, border:`1px solid ${G.border}` },
    danger:   { background:"#ef444420", color:G.red, border:`1px solid #ef444440` },
    amber:    { background:"#f59e0b20", color:G.amber, border:`1px solid #f59e0b40` },
    ghost:    { background:"transparent", color:G.muted },
  };
  return <button onClick={onClick} style={{...base,...vars[variant],...s}}>{children}</button>;
};

const Badge = ({status}) => {
  const map = { nuevo:["Nuevo",G.accent,"#25D36622"], proceso:["En proceso",G.amber,"#f59e0b22"], listo:["Listo","#60a5fa","#3b82f622"] };
  const [label,color,bg] = map[status]||[status,G.muted,G.border+"33"];
  return <span style={{fontSize:"11px",fontWeight:600,padding:"3px 9px",borderRadius:"20px",background:bg,color,letterSpacing:".4px",textTransform:"uppercase"}}>{label}</span>;
};

const Modal = ({children, onClose, title, width=480}) => (
  <div style={{position:"fixed",inset:0,background:"#000a",display:"flex",alignItems:"center",justifyContent:"center",zIndex:999}} onClick={e=>e.target===e.currentTarget&&onClose()}>
