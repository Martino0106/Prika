          <div style={{padding:"12px 16px",borderTop:`1px solid ${G.border}`,fontSize:"11px",color:G.muted}}>
            <div>{pedidos.filter(p=>p.estado==="nuevo").length} pedidos nuevos</div>
            <div style={{marginTop:"3px"}}>{inventario.filter(m=>m.stock<=m.minimo).length} items bajo stock</div>
          </div>
        </div>

        {/* Main */}
        <main style={{flex:1,padding:"28px",overflowY:"auto",maxWidth:"1100px"}}>
          {nav==="dashboard"   && <Dashboard pedidos={pedidos} inventario={inventario} eventos={eventos}/>}
          {nav==="whatsapp"    && <SeccionWhatsApp onImportar={importarDesdWA}/>}
          {nav==="pedidos"     && <SeccionPedidos pedidos={pedidos} setPedidos={setPedidos} setEventos={setEventos}/>}
          {nav==="inventario"  && <SeccionInventario inventario={inventario} setInventario={setInventario}/>}
          {nav==="calendario"  && <SeccionCalendario eventos={eventos} setEventos={setEventos} pedidos={pedidos}/>}
        </main>
      </div>
    </>
  );
}
