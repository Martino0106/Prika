// ── SECCIÓN PEDIDOS ────────────────────────────────────────────────────────
function SeccionPedidos({pedidos,setPedidos,setEventos}) {
  const [tab,setTab] = useState("nuevo");
  const [modal,setModal] = useState(null);
  const [form,setForm] = useState(null);
  const [filtro,setFiltro] = useState("");

  const tabs = [["nuevo","Nuevos 🟢"],["proceso","En Proceso 🟡"],["listo","Listos ✅"]];
  const counts = {nuevo:0,proceso:0,listo:0};
  pedidos.forEach(p=>counts[p.estado]++);

  const filtered = pedidos.filter(p=>p.estado===tab && (
    !filtro || p.cliente.toLowerCase().includes(filtro.toLowerCase()) ||
    p.id.toLowerCase().includes(filtro.toLowerCase()) ||
    p.telefono.includes(filtro)
  ));

  const avanzar = (p) => {
    const next = p.estado==="nuevo"?"proceso":p.estado==="proceso"?"listo":null;
    if(!next) return;
    setPedidos(ps=>ps.map(x=>x.id===p.id?{...x,estado:next}:x));
  };

  const eliminar = (id) => setPedidos(ps=>ps.filter(p=>p.id!==id));

  const guardarPedido = (data) => {
    if(data.id && pedidos.find(p=>p.id===data.id)) {
      setPedidos(ps=>ps.map(p=>p.id===data.id?data:p));
    } else {
      const newId = "P" + String(pedidos.length+1).padStart(3,"0");
      const nuevo = {...data, id:newId, estado:"nuevo", fecha:today()};
      setPedidos(ps=>[nuevo,...ps]);
      if(nuevo.despacho) {
        setEventos(evs=>[...evs,{id:"E"+Date.now(),titulo:`Despacho ${newId} - ${nuevo.cliente}`,fecha:nuevo.despacho,tipo:"despacho",pedidoId:newId}]);
      }
    }
    setForm(null);
  };

  return (
    <div>
      {/* Header */}
      <div style={{display:"flex",justifyContent:"space-between",alignItems:"center",marginBottom:"20px",flexWrap:"wrap",gap:"10px"}}>
        <div>
          <h2 style={{fontSize:"20px",fontWeight:700}}>📦 Pedidos</h2>
          <p style={{color:G.muted,fontSize:"13px",marginTop:"2px"}}>{pedidos.length} pedidos totales</p>
        </div>
        <div style={{display:"flex",gap:"8px",flexWrap:"wrap"}}>
          <input placeholder="🔍 Buscar pedido…" value={filtro} onChange={e=>setFiltro(e.target.value)} style={{width:"200px"}}/>
          <Btn onClick={()=>setForm({cliente:"",telefono:"",items:[{prod:"",cant:1,precio:0}],nota:"",despacho:today()})}>＋ Nuevo pedido</Btn>
          <Btn variant="secondary" onClick={()=>downloadCSV(toCSV(pedidos.filter(p=>p.estado===tab)),`pedidos-${tab}.csv`)}>⬇ Exportar Excel</Btn>
        </div>
      </div>

      {/* Tabs */}
      <div style={{display:"flex",gap:"6px",marginBottom:"16px"}}>
        {tabs.map(([key,label])=>(
          <button key={key} onClick={()=>setTab(key)} style={{
            padding:"8px 18px",borderRadius:"8px",border:`1px solid`,fontSize:"13px",fontWeight:500,transition:"all .15s",
            borderColor: tab===key ? G.accent : G.border,
            background: tab===key ? G.accent+"20" : G.card,
            color: tab===key ? G.accent : G.muted,
          }}>{label} <span style={{marginLeft:"4px",background:G.border,padding:"1px 7px",borderRadius:"10px",fontSize:"11px"}}>{counts[key]}</span></button>
        ))}
      </div>

      {/* Lista */}
      <div style={{display:"flex",flexDirection:"column",gap:"10px"}}>
        {filtered.length===0 && <div style={{textAlign:"center",padding:"60px",color:G.muted,border:`1px dashed ${G.border}`,borderRadius:"10px"}}>Sin pedidos en esta sección</div>}
        {filtered.map(p=>(
          <div key={p.id} className="slide-in" style={{background:G.card,border:`1px solid ${G.border}`,borderRadius:"10px",padding:"16px",display:"grid",gridTemplateColumns:"1fr auto",gap:"12px",alignItems:"start"}}>
            <div>
              <div style={{display:"flex",alignItems:"center",gap:"10px",marginBottom:"8px",flexWrap:"wrap"}}>
                <span style={{fontFamily:G.font,fontSize:"12px",color:G.muted}}>{p.id}</span>
                <span style={{fontWeight:600,fontSize:"15px"}}>{p.cliente}</span>
                <Badge status={p.estado}/>
                <span style={{fontSize:"12px",color:G.muted,marginLeft:"auto"}}>{p.fecha} {p.hora}</span>
              </div>
              <div style={{display:"flex",flexWrap:"wrap",gap:"6px",marginBottom:"8px"}}>
                {p.items.map((it,i)=>(
                  <span key={i} style={{background:G.bg,border:`1px solid ${G.border}`,borderRadius:"5px",padding:"3px 9px",fontSize:"12px"}}>
                    {it.prod} ×{it.cant} — {fmt(it.precio*it.cant)}
                  </span>
                ))}
              </div>
              <div style={{display:"flex",gap:"16px",fontSize:"12px",color:G.muted,flexWrap:"wrap"}}>
                <span>📱 {p.telefono}</span>
                {p.despacho && <span>🚚 Despacho: <strong style={{color:G.text}}>{p.despacho}</strong></span>}
                {p.nota && <span>📝 {p.nota}</span>}
                <span style={{marginLeft:"auto",color:G.accent,fontWeight:700,fontSize:"14px"}}>{fmt(p.total)}</span>
              </div>
            </div>
            <div style={{display:"flex",gap:"6px",flexDirection:"column"}}>
              {p.estado!=="listo" && <Btn size="sm" variant="amber" onClick={()=>avanzar(p)}>{p.estado==="nuevo"?"▶ Procesar":"✓ Listo"}</Btn>}
              <Btn size="sm" variant="secondary" onClick={()=>setModal(p)}>👁 Ver</Btn>
              <Btn size="sm" variant="secondary" onClick={()=>setForm(p)}>✏ Editar</Btn>
              <Btn size="sm" variant="danger" onClick={()=>eliminar(p.id)}>🗑</Btn>
            </div>
          </div>
        ))}
      </div>

      {/* Modal detalle */}
      {modal && <Modal title={`Pedido ${modal.id}`} onClose={()=>setModal(null)}>
        <div style={{display:"flex",flexDirection:"column",gap:"12px"}}>
          <Row label="Cliente" val={modal.cliente}/>
          <Row label="Teléfono" val={modal.telefono}/>
          <Row label="Estado" val={<Badge status={modal.estado}/>}/>
          <Row label="Fecha" val={`${modal.fecha} ${modal.hora}`}/>
          {modal.despacho && <Row label="Despacho" val={modal.despacho}/>}
          <div><div style={{color:G.muted,fontSize:"12px",marginBottom:"6px"}}>PRODUCTOS</div>
            {modal.items.map((it,i)=>(
              <div key={i} style={{display:"flex",justifyContent:"space-between",padding:"6px 0",borderBottom:`1px solid ${G.border}`,fontSize:"13px"}}>
                <span>{it.prod} ×{it.cant}</span><span>{fmt(it.precio*it.cant)}</span>
              </div>
            ))}
            <div style={{display:"flex",justifyContent:"space-between",padding:"8px 0",fontWeight:700}}>
              <span>TOTAL</span><span style={{color:G.accent}}>{fmt(modal.total)}</span>
            </div>
          </div>
          {modal.nota && <Row label="Nota" val={modal.nota}/>}
          <div style={{marginTop:"8px",padding:"12px",background:G.bg,borderRadius:"8px",border:`1px solid ${G.border}`}}>
            <div style={{fontSize:"12px",color:G.muted,marginBottom:"6px"}}>ENVIAR POR WHATSAPP</div>
            <a href={`https://wa.me/${modal.telefono.replace(/\D/g,"")}?text=${encodeURIComponent(`Hola ${modal.cliente}! Tu pedido ${modal.id} está ${modal.estado==="listo"?"listo para recoger":"siendo preparado"}. Total: ${fmt(modal.total)}`)}`}
               target="_blank" rel="noreferrer">
              <Btn variant="primary">💬 Enviar mensaje WA</Btn>
            </a>
          </div>
        </div>
      </Modal>}

      {/* Modal formulario */}
      {form && <FormPedido pedido={form} onGuardar={guardarPedido} onCerrar={()=>setForm(null)}/>}
    </div>
  );
}

const Row = ({label,val}) => (
  <div style={{display:"flex",gap:"12px",fontSize:"13px"}}>
    <span style={{color:G.muted,minWidth:"90px",flexShrink:0}}>{label}</span>
    <span>{val}</span>
  </div>
);

function FormPedido({pedido,onGuardar,onCerrar}) {
  const [d,setD] = useState({...pedido});
  const set = (k,v) => setD(p=>({...p,[k]:v}));
  const setItem = (i,k,v) => setD(p=>({...p,items:p.items.map((it,idx)=>idx===i?{...it,[k]:v}:it)}));
  const addItem = () => setD(p=>({...p,items:[...p.items,{prod:"",cant:1,precio:0}]}));
  const remItem = i => setD(p=>({...p,items:p.items.filter((_,idx)=>idx!==i)}));
  const total = d.items.reduce((s,it)=>s+(it.cant*(it.precio||0)),0);

  const guardar = () => {
    if(!d.cliente||!d.telefono) return alert("Cliente y teléfono son obligatorios");
    onGuardar({...d,total,hora:d.hora||new Date().toTimeString().slice(0,5)});
  };

  return (
    <Modal title={d.id?"Editar pedido":"Nuevo pedido"} onClose={onCerrar} width={560}>
      <div style={{display:"flex",flexDirection:"column",gap:"12px"}}>
        <div style={{display:"grid",gridTemplateColumns:"1fr 1fr",gap:"10px"}}>
          <div><label style={{fontSize:"12px",color:G.muted}}>Cliente *</label><br/><input value={d.cliente} onChange={e=>set("cliente",e.target.value)} style={{width:"100%",marginTop:"4px"}}/></div>
          <div><label style={{fontSize:"12px",color:G.muted}}>Teléfono *</label><br/><input value={d.telefono} onChange={e=>set("telefono",e.target.value)} style={{width:"100%",marginTop:"4px"}}/></div>
        </div>
        <div><label style={{fontSize:"12px",color:G.muted}}>Fecha despacho</label><br/><input type="date" value={d.despacho} onChange={e=>set("despacho",e.target.value)} style={{width:"100%",marginTop:"4px"}}/></div>
        <div>
          <div style={{display:"flex",justifyContent:"space-between",alignItems:"center",marginBottom:"8px"}}>
            <label style={{fontSize:"12px",color:G.muted}}>PRODUCTOS</label>
            <Btn size="sm" variant="secondary" onClick={addItem}>＋ Agregar</Btn>
          </div>
          {d.items.map((it,i)=>(
            <div key={i} style={{display:"grid",gridTemplateColumns:"1fr 60px 90px 28px",gap:"6px",marginBottom:"6px"}}>
              <input placeholder="Producto" value={it.prod} onChange={e=>setItem(i,"prod",e.target.value)}/>
              <input type="number" placeholder="Cant" min="1" value={it.cant} onChange={e=>setItem(i,"cant",+e.target.value)}/>
              <input type="number" placeholder="Precio" min="0" value={it.precio} onChange={e=>setItem(i,"precio",+e.target.value)}/>
              <button onClick={()=>remItem(i)} style={{background:"none",border:`1px solid ${G.border}`,borderRadius:"5px",color:G.red,cursor:"pointer"}}>✕</button>
            </div>
          ))}
          <div style={{textAlign:"right",fontSize:"13px",color:G.accent,fontWeight:700,marginTop:"4px"}}>Total: {fmt(total)}</div>
        </div>
        <div><label style={{fontSize:"12px",color:G.muted}}>Nota</label><br/><textarea value={d.nota} onChange={e=>set("nota",e.target.value)} rows={2} style={{width:"100%",marginTop:"4px",resize:"vertical"}}/></div>
        <div style={{display:"flex",gap:"8px",justifyContent:"flex-end",marginTop:"4px"}}>
          <Btn variant="secondary" onClick={onCerrar}>Cancelar</Btn>
          <Btn onClick={guardar}>Guardar pedido</Btn>
        </div>
      </div>
    </Modal>
  );
}

