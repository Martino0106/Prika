// ── SECCIÓN CALENDARIO ─────────────────────────────────────────────────────
function SeccionCalendario({eventos,setEventos,pedidos}) {
  const [mes,setMes] = useState(new Date(2026,3,1));
  const [sel,setSel] = useState(null);
  const [formEv,setFormEv] = useState(null);

  const year=mes.getFullYear(), month=mes.getMonth();
  const primerDia = new Date(year,month,1).getDay();
  const diasMes = new Date(year,month+1,0).getDate();
  const mesStr = mes.toLocaleDateString("es-CO",{month:"long",year:"numeric"});

  const evPorDia = {};
  eventos.forEach(e=>{ if(!evPorDia[e.fecha]) evPorDia[e.fecha]=[];  evPorDia[e.fecha].push(e); });

  const dayKey = d => `${year}-${String(month+1).padStart(2,"0")}-${String(d).padStart(2,"0")}`;
  const selEvs = sel ? (evPorDia[sel]||[]) : [];

  const guardarEv = (ev) => {
    if(ev.id&&eventos.find(e=>e.id===ev.id)) setEventos(es=>es.map(e=>e.id===ev.id?ev:e));
    else setEventos(es=>[...es,{...ev,id:"E"+Date.now()}]);
    setFormEv(null);
  };

  const days = ["Dom","Lun","Mar","Mié","Jue","Vie","Sáb"];
  const tipoColor = {despacho:G.accent,produccion:G.amber,otro:G.blue};

  return (
    <div>
      <div style={{display:"flex",justifyContent:"space-between",alignItems:"center",marginBottom:"20px",flexWrap:"wrap",gap:"10px"}}>
        <h2 style={{fontSize:"20px",fontWeight:700}}>🗓 Calendario</h2>
        <div style={{display:"flex",gap:"8px",alignItems:"center"}}>
          <Btn variant="secondary" size="sm" onClick={()=>setMes(new Date(year,month-1,1))}>‹</Btn>
          <span style={{fontSize:"14px",fontWeight:600,minWidth:"160px",textAlign:"center",textTransform:"capitalize"}}>{mesStr}</span>
          <Btn variant="secondary" size="sm" onClick={()=>setMes(new Date(year,month+1,1))}>›</Btn>
          <Btn onClick={()=>setFormEv({titulo:"",fecha:today(),tipo:"despacho",pedidoId:null})}>＋ Evento</Btn>
        </div>
      </div>

      <div style={{display:"grid",gridTemplateColumns:"1fr 280px",gap:"16px"}}>
        {/* Calendario */}
        <div style={{background:G.card,border:`1px solid ${G.border}`,borderRadius:"10px",overflow:"hidden"}}>
          <div style={{display:"grid",gridTemplateColumns:"repeat(7,1fr)",borderBottom:`1px solid ${G.border}`}}>
            {days.map(d=><div key={d} style={{padding:"10px 0",textAlign:"center",fontSize:"11px",fontWeight:600,color:G.muted,textTransform:"uppercase",letterSpacing:".5px"}}>{d}</div>)}
          </div>
          <div style={{display:"grid",gridTemplateColumns:"repeat(7,1fr)"}}>
            {Array(primerDia===0?6:primerDia-1).fill(null).map((_,i)=><div key={`e${i}`} style={{borderRight:`1px solid ${G.border}`,borderBottom:`1px solid ${G.border}`,minHeight:"80px"}}/>)}
            {Array.from({length:diasMes},(_,i)=>{
              const d=i+1, k=dayKey(d), evs=evPorDia[k]||[];
              const isToday=k===today(), isSel=k===sel;
              return (
                <div key={d} onClick={()=>setSel(isSel?null:k)} style={{borderRight:`1px solid ${G.border}`,borderBottom:`1px solid ${G.border}`,minHeight:"80px",padding:"6px",cursor:"pointer",background:isSel?G.accent+"12":isToday?G.accent+"08":"transparent",transition:"background .15s"}}>
                  <div style={{fontSize:"13px",fontWeight:isToday?700:400,color:isToday?G.accent:G.text,marginBottom:"4px"}}>{d}</div>
                  {evs.slice(0,3).map(ev=>(
                    <div key={ev.id} style={{fontSize:"10px",background:(tipoColor[ev.tipo]||G.muted)+"22",color:tipoColor[ev.tipo]||G.muted,borderRadius:"3px",padding:"1px 5px",marginBottom:"2px",whiteSpace:"nowrap",overflow:"hidden",textOverflow:"ellipsis"}}>{ev.titulo}</div>
                  ))}
                  {evs.length>3&&<div style={{fontSize:"10px",color:G.muted}}>+{evs.length-3} más</div>}
                </div>
              );
            })}
          </div>
        </div>

        {/* Panel lateral */}
        <div>
          {sel ? (
            <div style={{background:G.card,border:`1px solid ${G.border}`,borderRadius:"10px",padding:"16px"}}>
              <div style={{display:"flex",justifyContent:"space-between",alignItems:"center",marginBottom:"12px"}}>
                <span style={{fontWeight:600,fontSize:"14px"}}>{new Date(sel+"T12:00").toLocaleDateString("es-CO",{weekday:"long",day:"numeric",month:"long"})}</span>
                <Btn size="sm" onClick={()=>setFormEv({titulo:"",fecha:sel,tipo:"despacho",pedidoId:null})}>＋</Btn>
              </div>
              {selEvs.length===0 && <p style={{color:G.muted,fontSize:"13px"}}>Sin eventos</p>}
              {selEvs.map(ev=>(
                <div key={ev.id} style={{background:G.bg,border:`1px solid ${G.border}`,borderRadius:"7px",padding:"10px",marginBottom:"8px"}}>
                  <div style={{display:"flex",justifyContent:"space-between",alignItems:"start",gap:"8px"}}>
                    <div>
                      <div style={{fontSize:"13px",fontWeight:500,marginBottom:"4px"}}>{ev.titulo}</div>
                      <span style={{fontSize:"11px",background:(tipoColor[ev.tipo]||G.muted)+"22",color:tipoColor[ev.tipo]||G.muted,padding:"2px 7px",borderRadius:"3px"}}>{ev.tipo}</span>
                      {ev.pedidoId&&<span style={{fontSize:"11px",color:G.muted,marginLeft:"6px"}}>{ev.pedidoId}</span>}
                    </div>
                    <Btn size="sm" variant="danger" onClick={()=>setEventos(es=>es.filter(e=>e.id!==ev.id))}>🗑</Btn>
                  </div>
                </div>
              ))}
            </div>
          ) : (
            <div style={{background:G.card,border:`1px solid ${G.border}`,borderRadius:"10px",padding:"16px"}}>
              <div style={{fontWeight:600,fontSize:"14px",marginBottom:"12px"}}>Próximos eventos</div>
              {eventos.filter(e=>e.fecha>=today()).sort((a,b)=>a.fecha>b.fecha?1:-1).slice(0,8).map(ev=>(
                <div key={ev.id} style={{display:"flex",gap:"8px",marginBottom:"10px",fontSize:"13px"}}>
                  <span style={{color:tipoColor[ev.tipo]||G.muted,fontSize:"18px",lineHeight:1}}>●</span>
                  <div>
                    <div style={{fontWeight:500}}>{ev.titulo}</div>
                    <div style={{color:G.muted,fontSize:"12px"}}>{new Date(ev.fecha+"T12:00").toLocaleDateString("es-CO",{weekday:"short",day:"numeric",month:"short"})}</div>
                  </div>
                </div>
              ))}
            </div>
          )}

          {/* Leyenda */}
          <div style={{background:G.card,border:`1px solid ${G.border}`,borderRadius:"10px",padding:"14px",marginTop:"10px"}}>
            <div style={{fontSize:"11px",color:G.muted,marginBottom:"8px",fontWeight:600}}>LEYENDA</div>
            {Object.entries(tipoColor).map(([t,c])=>(
              <div key={t} style={{display:"flex",alignItems:"center",gap:"8px",marginBottom:"5px",fontSize:"12px"}}>
                <span style={{width:10,height:10,borderRadius:"50%",background:c,display:"inline-block"}}></span>
                <span style={{textTransform:"capitalize"}}>{t}</span>
              </div>
            ))}
          </div>
        </div>
      </div>

      {formEv && <Modal title="Nuevo evento" onClose={()=>setFormEv(null)}>
        <FormEvento ev={formEv} pedidos={pedidos} onGuardar={guardarEv} onCerrar={()=>setFormEv(null)}/>
      </Modal>}
    </div>
  );
}

